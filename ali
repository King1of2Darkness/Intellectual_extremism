<button id="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="العودة للأعلى">↑</button>

<script>
/* ===== نظام الصفحات ===== */
var currentPage = 0;
var totalPages = 7;

function goPage(n) {
  document.getElementById('page-' + currentPage).classList.remove('active');
  document.getElementById('tab-' + currentPage).classList.remove('active');
  currentPage = n;
  document.getElementById('page-' + n).classList.add('active');
  document.getElementById('tab-' + n).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
  document.getElementById('progress-bar').style.width = '0%';
}

/* ===== شريط التقدم وزر العودة ===== */
window.addEventListener('scroll', function() {
  var scrollable = document.documentElement.scrollHeight - window.innerHeight;
  var scrolled = window.scrollY;
  if(scrollable > 0) document.getElementById('progress-bar').style.width = ((scrolled/scrollable)*100) + '%';
  document.getElementById('back-to-top').style.display = scrolled > 300 ? 'block' : 'none';
});

/* ===== لوحة الإعدادات ===== */
var settingsOpen = false;
function toggleSettings() {
  settingsOpen = !settingsOpen;
  document.getElementById('settings-panel').classList.toggle('open', settingsOpen);
  document.getElementById('settings-overlay').classList.toggle('open', settingsOpen);
}

/* --- حجم الخط --- */
function applyFontSize(val) {
  document.querySelector('.main-container').style.fontSize = val + '%';
  document.getElementById('font-size-val').textContent = val + '%';
  localStorage.setItem('acc_fontSize', val);
}

/* --- تباعد الأسطر --- */
function applyLineHeight(val) {
  var lh = (val / 100).toFixed(1);
  document.querySelector('.main-container').style.lineHeight = lh;
  document.getElementById('line-height-val').textContent = lh;
  localStorage.setItem('acc_lineHeight', val);
}

/* --- تباعد الحروف --- */
function applyLetterSpacing(val) {
  document.querySelector('.main-container').style.letterSpacing = val + 'px';
  document.getElementById('letter-spacing-val').textContent = val + 'px';
  localStorage.setItem('acc_letterSpacing', val);
}

/* --- تباين عالٍ --- */
function applyHighContrast(on) {
  if (on) {
    document.body.style.setProperty('--hc', '1');
    document.querySelectorAll('p, li, .section-box, .highlight-box').forEach(function(el) {
      el.style.color = '#ffffff';
      el.style.textShadow = '0 0 1px #000';
    });
    document.querySelectorAll('.section-box').forEach(function(el){
      el.style.background = 'rgba(0,0,0,0.95)';
      el.style.borderColor = '#00ffff';
    });
  } else {
    document.querySelectorAll('p, li, .section-box, .highlight-box').forEach(function(el) {
      el.style.color = '';
      el.style.textShadow = '';
    });
    document.querySelectorAll('.section-box').forEach(function(el){
      el.style.background = '';
      el.style.borderColor = '';
    });
  }
  localStorage.setItem('acc_highContrast', on ? '1' : '0');
}

/* --- رمادي --- */
function applyGrayscale(on) {
  document.body.style.filter = on ? 'grayscale(100%)' : '';
  localStorage.setItem('acc_grayscale', on ? '1' : '0');
}

/* --- تمييز الروابط --- */
function applyHighlightLinks(on) {
  var style = document.getElementById('highlight-links-style');
  if (!style) {
    style = document.createElement('style');
    style.id = 'highlight-links-style';
    document.head.appendChild(style);
  }
  style.textContent = on ? '.page-tab,.page-card,.sp-color-btn{outline:2px solid #00bcd4!important;text-decoration:underline}' : '';
  localStorage.setItem('acc_highlightLinks', on ? '1' : '0');
}

/* --- تقليل الحركة --- */
function applyReduceMotion(on) {
  var style = document.getElementById('reduce-motion-style');
  if (!style) {
    style = document.createElement('style');
    style.id = 'reduce-motion-style';
    document.head.appendChild(style);
  }
  style.textContent = on ? '*{animation-duration:0.001s!important;transition-duration:0.001s!important}' : '';
  localStorage.setItem('acc_reduceMotion', on ? '1' : '0');
}

/* --- إيقاف الكيرسور المضيء --- */
function applyCursorEffects(off) {
  var cursor = document.getElementById('custom-cursor');
  if (cursor) cursor.style.display = off ? 'none' : 'block';
  window._cursorEffectsOff = off;
  localStorage.setItem('acc_cursorOff', off ? '1' : '0');
}

/* --- إيقاف توهج الخلفية --- */
function applyGlow(off) {
  document.querySelectorAll('.bg-glow').forEach(function(el){
    el.style.display = off ? 'none' : 'block';
  });
  localStorage.setItem('acc_glowOff', off ? '1' : '0');
}

/* --- تمييز التركيز --- */
function applyFocusHighlight(on) {
  var style = document.getElementById('focus-style');
  if (!style) {
    style = document.createElement('style');
    style.id = 'focus-style';
    document.head.appendChild(style);
  }
  style.textContent = on ? '*:focus{outline:3px solid #ffeb3b!important;outline-offset:3px!important}' : '';
  localStorage.setItem('acc_focus', on ? '1' : '0');
}

/* --- قراءة النص بصوت (TTS) --- */
var ttsEnabled = false;
var ttsUtterance = null;

function applyTTS(on) {
  ttsEnabled = on;
  document.getElementById('tts-voice-row').style.display = on ? 'flex' : 'none';
  if (!on && window.speechSynthesis) window.speechSynthesis.cancel();

  if (on) {
    document.querySelectorAll('.main-container p, .main-container li, .main-container h2, .main-container h3').forEach(function(el) {
      el.style.cursor = 'pointer!important';
      el.setAttribute('title', 'اضغط للاستماع');
      el.addEventListener('click', speakElement);
    });
  } else {
    document.querySelectorAll('.main-container p, .main-container li, .main-container h2, .main-container h3').forEach(function(el) {
      el.removeEventListener('click', speakElement);
      el.removeAttribute('title');
      el.style.outline = '';
    });
  }
  localStorage.setItem('acc_tts', on ? '1' : '0');
}

function speakElement(e) {
  if (!ttsEnabled || !window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  var text = e.currentTarget.textContent.trim();
  var rate = parseFloat(document.getElementById('tts-speed').value) || 1;
  var utt = new SpeechSynthesisUtterance(text);
  utt.lang = 'ar-SA';
  utt.rate = rate;
  e.currentTarget.style.outline = '2px solid #00bcd4';
  utt.onend = function() { e.currentTarget.style.outline = ''; };
  window.speechSynthesis.speak(utt);
}

/* --- لون خلفية النص --- */
function applyTextBg(color, btn) {
  document.querySelectorAll('.sp-color-btn').forEach(function(b){ b.classList.remove('active'); b.style.borderColor='transparent'; });
  btn.classList.add('active');
  btn.style.borderColor = '#00bcd4';
  var boxes = document.querySelectorAll('.section-box, .highlight-box, .watch-guide');
  if (color === 'none') {
    boxes.forEach(function(el){ el.style.backgroundColor = ''; });
  } else {
    boxes.forEach(function(el){ el.style.backgroundColor = color; });
    var isDark = color === '#2d2d2d';
    document.querySelectorAll('.section-box p, .section-box li, .highlight-box p').forEach(function(el){
      el.style.color = isDark ? '#f0f0f0' : '#111';
    });
  }
  localStorage.setItem('acc_textBg', color);
}

/* --- إعادة الضبط --- */
function resetAll() {
  applyFontSize(100); document.getElementById('font-size-slider').value = 100;
  applyLineHeight(190); document.getElementById('line-height-slider').value = 190;
  applyLetterSpacing(0); document.getElementById('letter-spacing-slider').value = 0;
  applyHighContrast(false); document.getElementById('high-contrast-toggle').checked = false;
  applyGrayscale(false); document.getElementById('grayscale-toggle').checked = false;
  applyHighlightLinks(false); document.getElementById('highlight-links-toggle').checked = false;
  applyReduceMotion(false); document.getElementById('reduce-motion-toggle').checked = false;
  applyCursorEffects(false); document.getElementById('cursor-effects-toggle').checked = false;
  applyGlow(false); document.getElementById('glow-toggle').checked = false;
  applyFocusHighlight(false); document.getElementById('focus-highlight-toggle').checked = false;
  applyTTS(false); document.getElementById('tts-toggle').checked = false;
  applyTextBg('none', document.querySelector('.sp-color-btn[data-bg="none"]'));
  localStorage.clear();
}

/* --- تحميل الإعدادات المحفوظة --- */
window.addEventListener('load', function() {
  var fs = localStorage.getItem('acc_fontSize');
  if (fs) { applyFontSize(fs); document.getElementById('font-size-slider').value = fs; }
  var lh = localStorage.getItem('acc_lineHeight');
  if (lh) { applyLineHeight(lh); document.getElementById('line-height-slider').value = lh; }
  var ls = localStorage.getItem('acc_letterSpacing');
  if (ls) { applyLetterSpacing(ls); document.getElementById('letter-spacing-slider').value = ls; }
  if (localStorage.getItem('acc_highContrast') === '1') { applyHighContrast(true); document.getElementById('high-contrast-toggle').checked = true; }
  if (localStorage.getItem('acc_grayscale') === '1') { applyGrayscale(true); document.getElementById('grayscale-toggle').checked = true; }
  if (localStorage.getItem('acc_highlightLinks') === '1') { applyHighlightLinks(true); document.getElementById('highlight-links-toggle').checked = true; }
  if (localStorage.getItem('acc_reduceMotion') === '1') { applyReduceMotion(true); document.getElementById('reduce-motion-toggle').checked = true; }
  if (localStorage.getItem('acc_cursorOff') === '1') { applyCursorEffects(true); document.getElementById('cursor-effects-toggle').checked = true; }
  if (localStorage.getItem('acc_glowOff') === '1') { applyGlow(true); document.getElementById('glow-toggle').checked = true; }
  if (localStorage.getItem('acc_focus') === '1') { applyFocusHighlight(true); document.getElementById('focus-highlight-toggle').checked = true; }
  if (localStorage.getItem('acc_tts') === '1') { applyTTS(true); document.getElementById('tts-toggle').checked = true; }
});




/* ===== شاشة الترحيب ===== */
var introSnowInterval=null;

function drawBolt(ctx,x1,y1,x2,y2,depth){
  if(depth<0)return;
  var pts=[{x:x1,y:y1}];
  var segs=14+Math.floor(Math.random()*6);
  for(var i=1;i<segs;i++){
    var t=i/segs;
    var jagged=depth===2?70:depth===1?40:20;
    pts.push({x:x1+(x2-x1)*t+(Math.random()-0.5)*jagged,y:y1+(y2-y1)*t+(Math.random()-0.5)*jagged*0.6});
  }
  pts.push({x:x2,y:y2});
  ctx.beginPath();
  ctx.strokeStyle=depth===2?'rgba(0,150,255,0.2)':'rgba(0,188,212,0.15)';
  ctx.lineWidth=depth===2?18:depth===1?10:5;
  ctx.shadowBlur=60; ctx.shadowColor='#0055ff';
  ctx.lineCap='round'; ctx.lineJoin='round';
  ctx.moveTo(pts[0].x,pts[0].y);
  pts.forEach(function(p){ctx.lineTo(p.x,p.y);}); ctx.stroke();
  ctx.beginPath();
  ctx.strokeStyle=depth===2?'rgba(0,220,255,0.5)':'rgba(0,200,255,0.3)';
  ctx.lineWidth=depth===2?8:depth===1?4:2; ctx.shadowBlur=30; ctx.shadowColor='#00bcd4';
  ctx.moveTo(pts[0].x,pts[0].y);
  pts.forEach(function(p){ctx.lineTo(p.x,p.y);}); ctx.stroke();
  ctx.beginPath();
  ctx.strokeStyle=depth===2?'#00eeff':'rgba(100,230,255,0.8)';
  ctx.lineWidth=depth===2?2.5:depth===1?1.5:0.8; ctx.shadowBlur=10; ctx.shadowColor='#00ffff';
  ctx.moveTo(pts[0].x,pts[0].y);
  pts.forEach(function(p){ctx.lineTo(p.x,p.y);}); ctx.stroke();
  ctx.beginPath();
  ctx.strokeStyle='rgba(255,255,255,'+(depth===2?'1':'0.7')+')';
  ctx.lineWidth=depth===2?1.2:0.6; ctx.shadowBlur=0;
  ctx.moveTo(pts[0].x,pts[0].y);
  pts.forEach(function(p){ctx.lineTo(p.x,p.y);}); ctx.stroke();
  if(depth>0){
    var numB=depth===2?3+Math.floor(Math.random()*3):1+Math.floor(Math.random()*2);
    for(var b=0;b<numB;b++){
      var bIdx=Math.floor(pts.length*0.2+Math.random()*pts.length*0.6);
      var bpt=pts[bIdx];
      var angle=(Math.random()-0.5)*Math.PI*1.4;
      var len=(depth===2?120:70)+Math.random()*100;
      drawBolt(ctx,bpt.x,bpt.y,bpt.x+Math.cos(angle)*len,bpt.y+Math.sin(angle)*len*0.7,depth-1);
    }
  }
}

function strikeSingleBolt(dir){
  var canvas=document.getElementById('lightning-canvas');
  var ctx=canvas.getContext('2d');
  canvas.width=window.innerWidth; canvas.height=window.innerHeight;
  var title=document.getElementById('intro-title');
  var rect=title?title.getBoundingClientRect():null;
  var cx=rect?(rect.left+rect.right)/2:canvas.width/2;
  var cy=rect?rect.top+rect.height/2:canvas.height/2;
  var r=Math.random;
  var targets={
    top:{bx:cx+(r()-0.5)*100,by:cy-350-r()*180},
    bottom:{bx:cx+(r()-0.5)*100,by:cy+350+r()*180},
    right:{bx:cx+350+r()*180,by:cy+(r()-0.5)*100},
    left:{bx:cx-350-r()*180,by:cy+(r()-0.5)*100},
    topright:{bx:cx+280+r()*120,by:cy-280-r()*120},
    topleft:{bx:cx-280-r()*120,by:cy-280-r()*120},
    bottomright:{bx:cx+280+r()*120,by:cy+280+r()*120},
    bottomleft:{bx:cx-280-r()*120,by:cy+280+r()*120}
  };
  var d=targets[dir]||targets.top;
  drawBolt(ctx,cx,cy,d.bx,d.by,2);
  if(title){title.style.textShadow='0 0 60px #fff,0 0 120px #00bcd4,0 0 200px #0055ff';setTimeout(function(){title.style.textShadow='0 0 40px #00bcd4,0 0 80px #0055ff';},180);}
  var is=document.getElementById('intro-screen');
  is.style.background='rgba(0,40,100,0.95)';
  setTimeout(function(){is.style.background='radial-gradient(ellipse at center,#000820 0%,#000005 100%)';},100);
  setTimeout(function(){ctx.clearRect(0,0,canvas.width,canvas.height);},260);
}

var allDirs=['top','bottom','right','left','topright','topleft','bottomright','bottomleft'];

function fireRandomBolts(count,spread){
  var shuffled=allDirs.slice().sort(function(){return Math.random()-0.5;});
  for(var i=0;i<count;i++){
    (function(dir,delay){setTimeout(function(){strikeSingleBolt(dir);},delay);})(shuffled[i%shuffled.length],Math.random()*spread);
  }
}

function createIntroSnow(){
  var symbols=["❄","❅","❆","·","•","✦","✧","*","❋","✼"];
  var snow=document.createElement("div");
  snow.classList.add("intro-snow");
  snow.innerHTML=symbols[Math.floor(Math.random()*symbols.length)];
  var size=Math.random()*25+8;
  snow.style.fontSize=size+"px";
  snow.style.left=(Math.random()*100)+"vw";
  snow.style.top="-50px";
  snow.style.color=Math.random()>0.6?'#a0e8ff':'#ffffff';
  snow.style.opacity=(Math.random()*0.6+0.4).toString();
  var duration=Math.random()*1.5+0.8;
  snow.style.animationDuration=duration+"s";
  snow.style.setProperty('--drift',((Math.random()-0.5)*150)+'px');
  snow.style.setProperty('--spin',((Math.random()-0.5)*720)+'deg');
  document.getElementById('intro-screen').appendChild(snow);
  setTimeout(function(){if(snow.parentNode)snow.remove();},(duration+0.3)*1000);
}

function startIntro(){
  var introScreen=document.getElementById('intro-screen');
  var mainSite=document.getElementById('main-site');
  setTimeout(function(){fireRandomBolts(3,600);},1400);
  setTimeout(function(){fireRandomBolts(2,400);},2200);
  setTimeout(function(){fireRandomBolts(3,500);},2800);
  setTimeout(function(){
    introSnowInterval=setInterval(createIntroSnow,18);
    for(var i=0;i<100;i++) setTimeout(createIntroSnow,i*12);
    setTimeout(function(){fireRandomBolts(2,300);},200);
    setTimeout(function(){fireRandomBolts(3,500);},800);
    setTimeout(function(){fireRandomBolts(2,400);},1500);
    setTimeout(function(){fireRandomBolts(3,600);},2000);
    setTimeout(function(){
      clearInterval(introSnowInterval);
      introScreen.classList.add('fade-out');
      setTimeout(function(){
        introScreen.style.display='none';
        mainSite.classList.add('visible');
      },1200);
    },2800);
  },3000);
}
window.addEventListener('load',startIntro);

/* ===== كيرسور ===== */
var cursorEl=document.createElement('div');
cursorEl.id='custom-cursor';
document.body.appendChild(cursorEl);
var hue=180,lastTrailTime=0;
setInterval(function(){
  hue=(hue+2)%360;
  cursorEl.style.background='radial-gradient(circle,#fff,hsl('+hue+',100%,60%))';
  cursorEl.style.boxShadow='0 0 12px hsl('+hue+',100%,70%),0 0 30px hsl('+hue+',100%,50%)';
},16);
document.addEventListener('mousemove',function(e){
  cursorEl.style.left=e.clientX+'px';
  cursorEl.style.top=e.clientY+'px';
  var now=Date.now();
  if(now-lastTrailTime>20){
    lastTrailTime=now;
    var trail=document.createElement('div');
    trail.classList.add('cursor-trail');
    var size=Math.random()*10+5;
    trail.style.width=size+'px'; trail.style.height=size+'px';
    trail.style.left=e.clientX+'px'; trail.style.top=e.clientY+'px';
    trail.style.background='radial-gradient(circle,hsl('+(hue+(Math.random()-0.5)*60)+',100%,80%),transparent)';
    var duration=Math.random()*0.5+0.3;
    trail.style.animationDuration=duration+'s';
    document.body.appendChild(trail);
    setTimeout(function(){if(trail.parentNode)trail.remove();},duration*1000);
  }
});
</script>
