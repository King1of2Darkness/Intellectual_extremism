  <div class="img-container">
    <img src="https://dreamsinterpretationz.com/wp-content/uploads/2023/05/%D8%AA%D9%81%D8%B3%D9%8A%D8%B1-%D8%AD%D9%84%D9%85-%D8%A7%D9%84%D8%B8%D9%84%D8%A7%D9%85-%D9%81%D9%8A-%D8%A7%D9%84%D8%B4%D8%A7%D8%B1%D8%B9-%D9%88%D8%A7%D9%84%D8%B3%D9%8A%D8%B1-%D9%81%D9%8A%D9%87-%D9%88%D9%85%D8%B4%D8%A7%D9%87%D8%AF%D8%AA%D9%87-%D9%84%D8%A7%D8%A8%D9%86-%D8%B3%D9%8A%D8%B1%D9%8A%D9%86.jpg" alt="مراحل تطور التطرف">
