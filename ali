<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>التطرف الفكري</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;cursor:none!important}
body{direction:rtl;text-align:right;font-family:Tahoma,Arial,sans-serif;line-height:1.9;background:#050a12;color:#eaeaea;overflow-x:hidden}

/* ===== شاشة الترحيب ===== */
#intro-screen{position:fixed;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse at center,#000820 0%,#000005 100%);z-index:999999;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}
#lightning-canvas{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1}
#intro-title{font-family:Tahoma,Arial,sans-serif;font-size:3.5em;color:#fff;text-align:center;letter-spacing:8px;position:relative;z-index:5;opacity:0;padding:30px 60px;animation:title-appear 1.4s ease 0.5s forwards;background:rgba(0,10,30,0.6);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(0,188,212,0.3);border-radius:20px;box-shadow:0 0 60px rgba(0,188,212,0.15)}
@keyframes title-appear{0%{opacity:0;transform:scale(0.8)}60%{opacity:1;transform:scale(1.05)}100%{opacity:1;transform:scale(1);text-shadow:0 0 40px #00bcd4,0 0 80px #0055ff}}
.intro-snow{position:absolute;pointer-events:none;animation:intro-fall linear forwards;z-index:4;user-select:none}
@keyframes intro-fall{0%{transform:translateY(-50px) translateX(0) rotate(0deg);opacity:0}5%{opacity:1}95%{opacity:1}100%{transform:translateY(110vh) translateX(var(--drift)) rotate(var(--spin));opacity:0}}
#intro-screen.fade-out{animation:screen-fadeout 1.2s ease forwards}
@keyframes screen-fadeout{0%{opacity:1}100%{opacity:0;pointer-events:none}}
#main-site{opacity:0;transition:opacity 1.2s ease}
#main-site.visible{opacity:1}

/* ===== شريط التقدم ===== */
#progress-bar{position:fixed;top:0;right:0;height:4px;width:0%;background:linear-gradient(to left,#00bcd4,#0055ff);z-index:99999;transition:width 0.1s ease}

/* ===== الهيدر ===== */
#site-header{position:fixed;top:0;right:0;left:0;z-index:99998;background:rgba(5,10,18,0.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,188,212,0.3);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:65px}
.header-title{color:#00bcd4;font-size:1.3em;font-weight:bold;letter-spacing:2px;display:flex;flex-direction:column;align-items:flex-end;animation:header-lightning 4s infinite}
.header-title span{font-size:0.5em;color:#80deea;letter-spacing:1px;font-weight:normal}
@keyframes header-lightning{0%,89%,100%{text-shadow:0 0 15px rgba(0,188,212,0.5);color:#00bcd4}90%{text-shadow:0 0 60px #fff,0 0 100px #00bcd4,0 0 150px #0055ff;color:#fff}93%{text-shadow:0 0 15px rgba(0,188,212,0.5);color:#00bcd4}96%{text-shadow:0 0 80px #fff,0 0 120px #00bcd4;color:#fff}}


/* ===== شريط التنقل بين الصفحات ===== */
#pages-nav{position:fixed;top:65px;right:0;left:0;z-index:99997;background:rgba(5,10,18,0.92);backdrop-filter:blur(8px);border-bottom:1px solid rgba(0,188,212,0.15);display:flex;align-items:center;overflow-x:auto;scrollbar-width:none;padding:0 10px;height:46px}
#pages-nav::-webkit-scrollbar{display:none}
.page-tab{flex-shrink:0;padding:0 16px;height:46px;display:flex;align-items:center;gap:6px;color:#778899;font-size:0.78em;cursor:pointer!important;border-bottom:2px solid transparent;transition:all 0.25s;white-space:nowrap;user-select:none}
.page-tab:hover{color:#00bcd4;background:rgba(0,188,212,0.05)}
.page-tab.active{color:#00bcd4;border-bottom-color:#00bcd4;background:rgba(0,188,212,0.08)}
.page-tab .tab-icon{font-size:0.95em}
.tab-sep{color:#1a2535;padding:0 4px;font-size:0.7em;flex-shrink:0}

/* ===== دوائر الخلفية ===== */
.bg-glow{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(90px);animation:glow-pulse 7s ease-in-out infinite alternate}
@keyframes glow-pulse{0%{opacity:0.03;transform:scale(1)}100%{opacity:0.10;transform:scale(1.2)}}

/* ===== الحاوية الرئيسية ===== */
.main-container{max-width:900px;margin:0 auto;padding:130px 25px 30px;position:relative;z-index:1}

/* ===== الصفحات ===== */
.page-content{display:none}
.page-content.active{display:block}

/* ===== عناصر المحتوى ===== */
.section-box{background:rgba(15,25,40,0.88);padding:20px 25px;border-radius:12px;margin-bottom:12px;border-right:4px solid #00bcd4}
h1{color:#fff;text-align:center;border-bottom:2px solid #00bcd4;padding-bottom:12px;font-size:2em;text-shadow:0 0 25px rgba(0,188,212,0.6);letter-spacing:3px;margin-bottom:20px}
h2{color:#00bcd4;margin-top:30px;border-bottom:1px solid #1a2535;padding-bottom:6px;font-size:1.35em}
h3{color:#80deea;margin-top:16px;margin-bottom:6px;font-size:1.05em}
p{margin-bottom:10px;font-size:0.97em}
ul{padding-right:20px;margin:8px 0}
ul li{margin-bottom:10px;line-height:1.8}
.img-container{text-align:center;margin:20px 0}
.img-container img{max-width:90%;border-radius:12px;box-shadow:0 0 25px rgba(0,188,212,0.3)}
.highlight-box{background:linear-gradient(135deg,#0d2233,#0a1a2e);border:2px solid #00bcd4;border-radius:14px;padding:25px 30px;margin:25px 0;text-align:center;font-size:1.05em;color:#e0f7fa;box-shadow:0 0 30px rgba(0,188,212,0.2)}

/* ===== بطاقة طريقة المشاهدة ===== */
.watch-guide{background:linear-gradient(135deg,#0a1f2e,#061524);border:2px solid #00bcd4;border-radius:16px;padding:25px 30px;margin-bottom:30px;box-shadow:0 0 40px rgba(0,188,212,0.25)}
.watch-guide h2{color:#00bcd4;margin-top:0;font-size:1.25em;border:none;text-align:center}
.watch-guide .step{display:flex;align-items:flex-start;gap:15px;margin:15px 0;padding:12px 15px;background:rgba(0,188,212,0.07);border-radius:10px}
.watch-guide .step-num{background:#00bcd4;color:#000;font-weight:bold;border-radius:50%;min-width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:0.9em;flex-shrink:0}

/* ===== عنوان الصفحة مع أيقونة ===== */
.page-header{display:flex;align-items:center;gap:15px;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(0,188,212,0.2)}
.page-icon{font-size:2.2em;filter:drop-shadow(0 0 10px rgba(0,188,212,0.5))}
.page-title-wrap h1{border:none;padding:0;margin:0;text-align:right;font-size:1.7em}
.page-title-wrap p{color:#8899aa;font-size:0.88em;margin:4px 0 0}

/* ===== بطاقات صغيرة في الصفحة الرئيسية ===== */
.pages-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin:20px 0}
.page-card{background:rgba(15,25,40,0.88);border:1px solid rgba(0,188,212,0.2);border-radius:12px;padding:18px;cursor:pointer!important;transition:all 0.25s;text-align:center}
.page-card:hover{border-color:#00bcd4;background:rgba(0,188,212,0.08);transform:translateY(-2px)}
.page-card .pc-icon{font-size:1.8em;display:block;margin-bottom:8px}
.page-card .pc-title{color:#00bcd4;font-size:0.9em;font-weight:bold;display:block;margin-bottom:5px}
.page-card .pc-desc{color:#778899;font-size:0.75em;line-height:1.5}

/* ===== الفوتر ===== */
footer{text-align:center;padding:30px 20px;margin-top:40px;border-top:1px solid #1a3040;color:#556677;font-size:0.88em}
footer .team-name{color:#00bcd4;font-weight:bold;font-size:1.1em}
footer .footer-note{color:#334455;font-size:0.78em;margin-top:8px}

/* ===== زر العودة للأعلى ===== */
#back-to-top{position:fixed;bottom:25px;left:25px;background:#00bcd4;color:#000;border:none;border-radius:50%;width:44px;height:44px;font-size:1.3em;cursor:pointer!important;z-index:9999;display:none;box-shadow:0 0 15px rgba(0,188,212,0.5);font-weight:bold}



/* ===== كيرسور ===== */
#custom-cursor{position:fixed;width:18px;height:18px;background:radial-gradient(circle,#fff,#00bcd4);border-radius:50%;pointer-events:none;z-index:9999999;transform:translate(-50%,-50%);box-shadow:0 0 10px #00bcd4,0 0 25px #0055ff,0 0 50px rgba(0,188,212,0.5);transition:transform 0.05s ease}
.cursor-trail{position:fixed;border-radius:50%;pointer-events:none;z-index:9999998;transform:translate(-50%,-50%);background:radial-gradient(circle,#00bcd4,#0055ff);animation:trail-fade linear forwards}
@keyframes trail-fade{0%{opacity:0.8}100%{opacity:0;transform:translate(-50%,-50%) scale(0.1)}}

/* ===== زر الإعدادات ===== */
#settings-btn{background:rgba(0,188,212,0.1);border:1px solid #00bcd4;color:#00bcd4;border-radius:8px;padding:7px 14px;cursor:pointer!important;font-size:0.82em;font-family:Tahoma;transition:all 0.2s;white-space:nowrap;display:flex;align-items:center;gap:6px}
#settings-btn:hover{background:rgba(0,188,212,0.25)}

/* ===== لوحة الإعدادات - overlay ===== */
#settings-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999990;opacity:0;pointer-events:none;transition:opacity 0.3s;backdrop-filter:blur(4px)}
#settings-overlay.open{opacity:1;pointer-events:all}
#settings-panel{position:fixed;top:0;left:0;width:340px;height:100vh;background:rgba(6,14,26,0.98);border-left:1px solid rgba(0,188,212,0.35);z-index:9999995;transform:translateX(-100%);transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);overflow-y:auto;padding:0 0 40px}
#settings-panel.open{transform:translateX(0)}
.sp-header{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;border-bottom:1px solid rgba(0,188,212,0.2);background:rgba(0,188,212,0.05);position:sticky;top:0;z-index:2}
.sp-header h3{color:#00bcd4;font-size:1em;margin:0;display:flex;align-items:center;gap:8px}
#settings-close{background:rgba(0,188,212,0.1);border:1px solid rgba(0,188,212,0.3);color:#00bcd4;border-radius:6px;width:30px;height:30px;cursor:pointer!important;font-size:1em;display:flex;align-items:center;justify-content:center;transition:background 0.2s}
#settings-close:hover{background:rgba(0,188,212,0.3)}
.sp-section{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,0.05)}
.sp-section-title{font-size:0.72em;color:#00bcd4;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:6px;opacity:0.85}
.sp-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:10px}
.sp-row:last-child{margin-bottom:0}
.sp-label{font-size:0.85em;color:#cdd6e0;line-height:1.4;flex:1}
.sp-label small{display:block;color:#556677;font-size:0.8em;margin-top:2px}

/* toggle switch */
.sp-toggle{position:relative;width:42px;height:24px;flex-shrink:0}
.sp-toggle input{opacity:0;width:0;height:0;position:absolute}
.sp-toggle-track{position:absolute;inset:0;background:#1a2535;border-radius:24px;cursor:pointer!important;transition:background 0.25s;border:1px solid #2a3a50}
.sp-toggle input:checked+.sp-toggle-track{background:#00bcd4;border-color:#00bcd4}
.sp-toggle-track::after{content:'';position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:2px;right:2px;transition:right 0.25s;box-shadow:0 1px 4px rgba(0,0,0,0.4)}
.sp-toggle input:checked+.sp-toggle-track::after{right:calc(100% - 20px)}

/* sliders */
.sp-slider-wrap{margin-top:8px}
.sp-slider-row{display:flex;align-items:center;gap:10px}
.sp-slider-row input[type=range]{flex:1;accent-color:#00bcd4;height:4px;cursor:pointer!important}
.sp-slider-val{font-size:0.8em;color:#00bcd4;min-width:32px;text-align:center}

/* color buttons */
.sp-colors{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
.sp-color-btn{width:28px;height:28px;border-radius:50%;border:2px solid transparent;cursor:pointer!important;transition:transform 0.15s,border-color 0.15s}
.sp-color-btn:hover,.sp-color-btn.active{transform:scale(1.2);border-color:#fff}

/* تجاوب الموبايل ===== */
@media(max-width:768px){.main-container{padding:125px 12px 20px}.page-tab{padding:0 10px;font-size:0.7em}h1{font-size:1.5em}#pages-nav{height:42px}#site-header{height:55px}#pages-nav{top:55px}.main-container{padding-top:115px!important}#settings-panel{width:100%;left:0}}
</style>
</head>
<body>

<!-- شاشة الترحيب -->
<div id="intro-screen">
  <canvas id="lightning-canvas"></canvas>
  <div id="intro-title">❄ التطرف الفكري ❄</div>
</div>

<div id="main-site">
<div id="progress-bar"></div>

<!-- دوائر الخلفية -->
<div class="bg-glow" style="width:700px;height:700px;background:#0044cc;top:-200px;right:-200px;animation-delay:0s"></div>
<div class="bg-glow" style="width:500px;height:500px;background:#00bcd4;top:35%;left:-150px;animation-delay:2.5s"></div>
<div class="bg-glow" style="width:600px;height:600px;background:#001a4d;bottom:5%;right:-100px;animation-delay:5s"></div>

<!-- الهيدر -->
<div id="site-header">
  <div class="header-title">❄ التطرف الفكري<span>مدرسة عبد الملك بن مروان الثانوية</span></div>
  <button id="settings-btn" onclick="toggleSettings()">⚙ الإعدادات</button>
</div>

<!-- لوحة الإعدادات -->
<div id="settings-overlay" onclick="toggleSettings()"></div>
<div id="settings-panel" role="dialog" aria-label="إعدادات إمكانية الوصول">
  <div class="sp-header">
    <h3>⚙ الإعدادات وإمكانية الوصول</h3>
    <button id="settings-close" onclick="toggleSettings()" aria-label="إغلاق الإعدادات">✕</button>
  </div>

  <!-- 1. قراءة النص -->
  <div class="sp-section">
    <div class="sp-section-title">♿ إمكانية القراءة</div>

    <div class="sp-row">
      <div class="sp-label">حجم الخط
        <small>تكبير أو تصغير النص في الصفحة</small>
      </div>
    </div>
    <div class="sp-slider-wrap">
      <div class="sp-slider-row">
        <span style="font-size:0.75em;color:#556677">أ</span>
        <input type="range" min="80" max="160" value="100" id="font-size-slider" oninput="applyFontSize(this.value)">
        <span style="font-size:1.1em;color:#556677">أ</span>
        <span class="sp-slider-val" id="font-size-val">100%</span>
      </div>
    </div>

    <div class="sp-row" style="margin-top:16px">
      <div class="sp-label">تباعد الأسطر
        <small>زيادة المسافة بين الأسطر</small>
      </div>
    </div>
    <div class="sp-slider-wrap">
      <div class="sp-slider-row">
        <input type="range" min="140" max="260" value="190" id="line-height-slider" oninput="applyLineHeight(this.value)">
        <span class="sp-slider-val" id="line-height-val">1.9</span>
      </div>
    </div>

    <div class="sp-row" style="margin-top:16px">
      <div class="sp-label">تباعد الحروف
        <small>زيادة المسافة بين الكلمات والحروف</small>
      </div>
    </div>
    <div class="sp-slider-wrap">
      <div class="sp-slider-row">
        <input type="range" min="0" max="6" value="0" step="0.5" id="letter-spacing-slider" oninput="applyLetterSpacing(this.value)">
        <span class="sp-slider-val" id="letter-spacing-val">0</span>
      </div>
    </div>
  </div>

  <!-- 2. التباين والألوان -->
  <div class="sp-section">
    <div class="sp-section-title">🎨 التباين والألوان</div>

    <div class="sp-row">
      <div class="sp-label">وضع التباين العالي
        <small>يجعل النصوص أوضح للمكفوفين جزئياً</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="high-contrast-toggle" onchange="applyHighContrast(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div class="sp-row">
      <div class="sp-label">وضع اللون الأحادي
        <small>يلغي الألوان للمصابين بعمى الألوان</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="grayscale-toggle" onchange="applyGrayscale(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div class="sp-row">
      <div class="sp-label">تمييز الروابط
        <small>يضع خطاً تحت الروابط وعناصر النقر</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="highlight-links-toggle" onchange="applyHighlightLinks(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div style="margin-top:8px">
      <div class="sp-label" style="margin-bottom:8px">لون خلفية النص
        <small>يساعد على التخفيف من صعوبة القراءة (ديسلكسيا)</small>
      </div>
      <div class="sp-colors">
        <div class="sp-color-btn active" data-bg="none" style="background:#1a2535;border-color:#00bcd4" onclick="applyTextBg('none',this)" title="بدون لون"></div>
        <div class="sp-color-btn" data-bg="#fffde7" style="background:#fffde7" onclick="applyTextBg('#fffde7',this)" title="أصفر فاتح"></div>
        <div class="sp-color-btn" data-bg="#e8f5e9" style="background:#e8f5e9" onclick="applyTextBg('#e8f5e9',this)" title="أخضر فاتح"></div>
        <div class="sp-color-btn" data-bg="#e3f2fd" style="background:#e3f2fd" onclick="applyTextBg('#e3f2fd',this)" title="أزرق فاتح"></div>
        <div class="sp-color-btn" data-bg="#fce4ec" style="background:#fce4ec" onclick="applyTextBg('#fce4ec',this)" title="وردي فاتح"></div>
        <div class="sp-color-btn" data-bg="#2d2d2d" style="background:#2d2d2d" onclick="applyTextBg('#2d2d2d',this)" title="رمادي داكن"></div>
      </div>
    </div>
  </div>

  <!-- 3. الحركة والتأثيرات -->
  <div class="sp-section">
    <div class="sp-section-title">🎞 الحركة والتأثيرات</div>

    <div class="sp-row">
      <div class="sp-label">تقليل الحركة
        <small>إيقاف الرسوم المتحركة لمن يعانون من الدوار</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="reduce-motion-toggle" onchange="applyReduceMotion(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div class="sp-row">
      <div class="sp-label">إيقاف تأثيرات الكيرسور
        <small>إزالة الذيل المضيء خلف المؤشر</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="cursor-effects-toggle" onchange="applyCursorEffects(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div class="sp-row">
      <div class="sp-label">إيقاف توهج الخلفية
        <small>إزالة دوائر الضوء في الخلفية</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="glow-toggle" onchange="applyGlow(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>
  </div>

  <!-- 4. التنقل والتركيز -->
  <div class="sp-section">
    <div class="sp-section-title">⌨ التنقل والتركيز</div>

    <div class="sp-row">
      <div class="sp-label">تمييز التركيز بالكيبورد
        <small>يظهر إطاراً واضحاً حول العنصر المحدد</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="focus-highlight-toggle" onchange="applyFocusHighlight(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div class="sp-row">
      <div class="sp-label">قراءة النص بصوت
        <small>اضغط على أي فقرة لسماعها بصوت عالٍ</small>
      </div>
      <label class="sp-toggle">
        <input type="checkbox" id="tts-toggle" onchange="applyTTS(this.checked)">
        <div class="sp-toggle-track"></div>
      </label>
    </div>

    <div id="tts-voice-row" class="sp-row" style="display:none;margin-top:-6px">
      <div class="sp-label">سرعة القراءة</div>
      <div class="sp-slider-row" style="flex:1;margin-right:10px">
        <input type="range" min="0.5" max="2" value="1" step="0.1" id="tts-speed" oninput="document.getElementById('tts-speed-val').textContent=parseFloat(this.value).toFixed(1)+'x'">
        <span class="sp-slider-val" id="tts-speed-val">1.0x</span>
      </div>
    </div>
  </div>

  <!-- 5. إعادة الضبط -->
